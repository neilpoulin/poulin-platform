{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  "enabled_providers": [
    "opencode",
    "openai"
  ],
  "mcp": {
    "linear": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "--header",
        "Authorization: Bearer ${LINEAR_API_KEY}",
        "https://mcp.linear.app/mcp"
      ]
    },
    "supabase": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "--header",
        "Authorization: Bearer ${SUPABASE_ACCESS_TOKEN}",
        "https://mcp.supabase.com/mcp?project_ref=pbasbmocqguzysofwqoy"
      ]
    }
  }
}
